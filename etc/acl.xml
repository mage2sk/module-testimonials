<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:Acl/etc/acl.xsd">
    <acl>
        <resources>
            <resource id="Magento_Backend::admin">
                <resource id="Panth_Core::panth_extensions" title="Panth Extensions">
                    <resource id="Panth_Testimonials::testimonials" title="Testimonials" sortOrder="30">
                        <resource id="Panth_Testimonials::manage_testimonials" title="Manage Testimonials" sortOrder="10"/>
                        <resource id="Panth_Testimonials::manage_categories" title="Manage Categories" sortOrder="20"/>
                        <resource id="Panth_Testimonials::configuration" title="Configuration" sortOrder="30"/>
                    </resource>
                </resource>
                <resource id="Magento_Backend::stores">
                    <resource id="Magento_Backend::stores_settings">
                        <resource id="Magento_Config::config">
                            <resource id="Panth_Testimonials::config" title="Panth Testimonials" sortOrder="100"/>
                        </resource>
                    </resource>
                </resource>
            </resource>
        </resources>
    </acl>
</config>
