<script>
document.addEventListener('DOMContentLoaded', function() {
    'use strict';

    var form = document.getElementById('testimonial-submit-form');
    if (!form) return;

    var ratingValue = document.getElementById('rating-value');
    var starPicker = document.getElementById('star-picker');
    var starBtns = starPicker.querySelectorAll('.star-btn');
    var starLabel = document.getElementById('star-label');
    var submitBtn = document.getElementById('submit-btn');
    var btnText = submitBtn.querySelector('.btn-text');
    var btnLoader = submitBtn.querySelector('.btn-loader');
    var fileInput = document.getElementById('testimonial-photo');
    var filePlaceholder = document.getElementById('file-placeholder');
    var filePreview = document.getElementById('file-preview');
    var previewImage = document.getElementById('preview-image');
    var fileRemove = document.getElementById('file-remove');

    var labels = ['', 'Poor', 'Fair', 'Good', 'Very Good', 'Excellent'];
    var selectedRating = 0;

    // Star rating picker
    function updateStars(rating, isHover) {
        starBtns.forEach(function(btn, idx) {
            var val = idx + 1;
            if (isHover) {
                btn.classList.toggle('hover', val <= rating);
            } else {
                btn.classList.toggle('active', val <= rating);
                btn.classList.remove('hover');
                btn.setAttribute('aria-checked', val <= rating ? 'true' : 'false');
            }
        });
        if (rating > 0) {
            starLabel.textContent = labels[rating] || '';
        }
    }

    starBtns.forEach(function(btn) {
        btn.addEventListener('click', function() {
            selectedRating = parseInt(this.getAttribute('data-rating'));
            ratingValue.value = selectedRating;
            updateStars(selectedRating, false);
        });
        btn.addEventListener('mouseenter', function() {
            updateStars(parseInt(this.getAttribute('data-rating')), true);
        });
    });

    starPicker.addEventListener('mouseleave', function() {
        updateStars(selectedRating, false);
    });

    // File upload preview
    fileInput.addEventListener('change', function() {
        var file = this.files[0];
        if (file) {
            var reader = new FileReader();
            reader.onload = function(e) {
                previewImage.src = e.target.result;
                filePlaceholder.style.display = 'none';
                filePreview.style.display = 'flex';
                fileInput.style.display = 'none';
            };
            reader.readAsDataURL(file);
        }
    });

    fileRemove.addEventListener('click', function() {
        fileInput.value = '';
        previewImage.src = '';
        filePlaceholder.style.display = 'flex';
        filePreview.style.display = 'none';
        fileInput.style.display = 'block';
    });

    // Form key from cookie
    function getFormKey() {
        var match = document.cookie.match(/form_key=([^;]+)/);
        return match ? match[1] : '';
    }

    // Show toast
    function showToast(message, type) {
        var toast = document.getElementById('submit-toast');
        var toastMsg = document.getElementById('toast-message');
        toastMsg.textContent = message;
        toast.className = 'submit-toast ' + type;
        toast.style.display = 'block';
        toast.style.opacity = '1';
        setTimeout(function() {
            toast.style.opacity = '0';
            setTimeout(function() { toast.style.display = 'none'; }, 300);
        }, 4000);
    }

    // Clear errors
    function clearErrors() {
        form.querySelectorAll('.field-error').forEach(function(el) { el.textContent = ''; });
        form.querySelectorAll('.field-input, .field-textarea').forEach(function(el) { el.classList.remove('error'); });
    }

    // Validate
    function validate() {
        clearErrors();
        var valid = true;

        var name = form.querySelector('[name="customer_name"]');
        if (!name.value.trim()) {
            showFieldError('customer_name', 'Name is required.');
            name.classList.add('error');
            valid = false;
        }

        var email = form.querySelector('[name="customer_email"]');
        var emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
        if (!email.value.trim()) {
            showFieldError('customer_email', 'Email is required.');
            email.classList.add('error');
            valid = false;
        } else if (!emailRegex.test(email.value.trim())) {
            showFieldError('customer_email', 'Please enter a valid email.');
            email.classList.add('error');
            valid = false;
        }

        if (!ratingValue.value) {
            showFieldError('rating', 'Please select a rating.');
            valid = false;
        }

        var title = form.querySelector('[name="title"]');
        if (!title.value.trim()) {
            showFieldError('title', 'Title is required.');
            title.classList.add('error');
            valid = false;
        }

        var content = form.querySelector('[name="content"]');
        if (!content.value.trim()) {
            showFieldError('content', 'Testimonial content is required.');
            content.classList.add('error');
            valid = false;
        }

        return valid;
    }

    function showFieldError(field, msg) {
        var el = form.querySelector('[data-error="' + field + '"]');
        if (el) el.textContent = msg;
    }

    // Submit via XHR
    form.addEventListener('submit', function(e) {
        e.preventDefault();
        if (!validate()) return;

        submitBtn.disabled = true;
        btnText.style.display = 'none';
        btnLoader.style.display = 'inline-flex';

        var formData = new FormData(form);
        formData.append('form_key', getFormKey());

        var xhr = new XMLHttpRequest();
        xhr.open('POST', form.action, true);
        xhr.setRequestHeader('X-Requested-With', 'XMLHttpRequest');

        xhr.onload = function() {
            submitBtn.disabled = false;
            btnText.style.display = 'inline';
            btnLoader.style.display = 'none';

            if (xhr.status >= 200 && xhr.status < 300) {
                try {
                    var resp = JSON.parse(xhr.responseText);
                    if (resp.success) {
                        showToast(resp.message || 'Thank you! Your testimonial has been submitted for review.', 'success');
                        form.reset();
                        selectedRating = 0;
                        updateStars(0, false);
                        ratingValue.value = '';
                        starLabel.textContent = '';
                        fileRemove.click();
                    } else {
                        showToast(resp.message || 'Something went wrong. Please try again.', 'error');
                    }
                } catch (ex) {
                    showToast('Thank you! Your testimonial has been submitted.', 'success');
                    form.reset();
                    selectedRating = 0;
                    updateStars(0, false);
                }
            } else {
                showToast('Submission failed. Please try again.', 'error');
            }
        };

        xhr.onerror = function() {
            submitBtn.disabled = false;
            btnText.style.display = 'inline';
            btnLoader.style.display = 'none';
            showToast('Network error. Please check your connection.', 'error');
        };

        xhr.send(formData);
    });
});
</script>
