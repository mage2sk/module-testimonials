<?php
/**
 * Panth Testimonials — Single View Template (Luma)
 * Vanilla JS, DM Sans, px units
 *
 * @var $block \Panth\Testimonials\Block\View
 * @var $escaper \Magento\Framework\Escaper
 */

$testimonial = $block->getTestimonial();
if (!$testimonial) {
    return '';
}

$backUrl = $block->getBackUrl();
$categoryName = $block->getCategoryName();
$rating = (int) $testimonial->getRating();
$createdAt = $testimonial->getCreatedAt();
$formattedDate = $createdAt ? date('F j, Y', strtotime($createdAt)) : '';

$nameParts = explode(' ', $testimonial->getCustomerName());
$initials = strtoupper(substr($nameParts[0], 0, 1));
if (isset($nameParts[1])) {
    $initials .= strtoupper(substr($nameParts[1], 0, 1));
}

$meta = [];
if ($testimonial->getCustomerTitle()) {
    $meta[] = $testimonial->getCustomerTitle();
}
if ($testimonial->getCustomerCompany()) {
    $meta[] = $testimonial->getCustomerCompany();
}
?>

<div class="panth-testimonials-module panth-testimonial-view">
    <!-- Back Link -->
    <a href="<?= $escaper->escapeUrl($backUrl) ?>" class="testimonial-back-link">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
        <?= $escaper->escapeHtml(__('Back to Testimonials')) ?>
    </a>

    <!-- Main Card -->
    <div class="testimonial-detail-card">
        <!-- Rating -->
        <?php if ($rating > 0): ?>
            <div class="testimonial-rating-large" aria-label="<?= $escaper->escapeHtmlAttr(__('Rating: %1 out of 5', $rating)) ?>">
                <?php for ($i = 1; $i <= 5; $i++): ?>
                    <span class="star <?= $i <= $rating ? 'filled' : '' ?>">&#9733;</span>
                <?php endfor; ?>
            </div>
        <?php endif; ?>

        <!-- Title -->
        <?php if ($testimonial->getTitle()): ?>
            <h1 class="testimonial-detail-title"><?= $escaper->escapeHtml($testimonial->getTitle()) ?></h1>
        <?php endif; ?>

        <!-- Full Content -->
        <div class="testimonial-detail-content">
            <span class="quote-mark-large">&ldquo;</span>
            <?= /** @noEscape */ nl2br($escaper->escapeHtml($testimonial->getContent())) ?>
        </div>

        <!-- Author Section -->
        <div class="testimonial-detail-author">
            <div class="author-avatar-large">
                <?php if ($testimonial->getCustomerImage()): ?>
                    <img src="<?= $escaper->escapeUrl($testimonial->getCustomerImage()) ?>"
                         alt="<?= $escaper->escapeHtmlAttr($testimonial->getCustomerName()) ?>"
                         width="80" height="80" loading="lazy"/>
                <?php else: ?>
                    <span class="avatar-initials-large"><?= $escaper->escapeHtml($initials) ?></span>
                <?php endif; ?>
            </div>
            <div class="author-details">
                <span class="author-name-large"><?= $escaper->escapeHtml($testimonial->getCustomerName()) ?></span>
                <?php if (!empty($meta)): ?>
                    <span class="author-meta-large"><?= $escaper->escapeHtml(implode(', ', $meta)) ?></span>
                <?php endif; ?>
            </div>
        </div>

        <!-- Meta Row -->
        <div class="testimonial-detail-meta">
            <?php if ($categoryName): ?>
                <span class="category-badge"><?= $escaper->escapeHtml($categoryName) ?></span>
            <?php endif; ?>
            <?php if ($formattedDate): ?>
                <span class="date-posted"><?= $escaper->escapeHtml($formattedDate) ?></span>
            <?php endif; ?>
        </div>
    </div>
</div>

