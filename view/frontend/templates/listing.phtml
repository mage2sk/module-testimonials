<script>
// Mouse-wheel horizontal scroll for the testimonials category tab strip.
// By default `overflow-x: auto` containers only respond to vertical wheel
// when the user holds Shift. This handler converts vertical wheel deltas
// into horizontal scrollLeft so the user can scroll the tabs with a
// regular mouse wheel as well as touch / scrollbar drag.
(function () {
    'use strict';
    function wireWheel(el) {
        if (!el || el.dataset.panthWheelBound === '1') return;
        el.dataset.panthWheelBound = '1';
        el.addEventListener('wheel', function (e) {
            // Only intercept when content actually overflows horizontally
            if (el.scrollWidth <= el.clientWidth + 1) return;
            // If the user is scrolling more horizontally than vertically
            // (trackpad horizontal swipe), let the browser handle it.
            if (Math.abs(e.deltaY) <= Math.abs(e.deltaX)) return;
            // At extreme edges, do not preventDefault so page scroll resumes
            var atLeft = el.scrollLeft <= 0 && e.deltaY < 0;
            var atRight = (el.scrollLeft + el.clientWidth) >= (el.scrollWidth - 1) && e.deltaY > 0;
            if (atLeft || atRight) return;
            e.preventDefault();
            el.scrollLeft += e.deltaY;
        }, { passive: false });
    }
    function init() {
        document.querySelectorAll('.panth-tt-tabs-scroll').forEach(wireWheel);
    }
    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', init);
    } else {
        init();
    }
})();
</script>
