<?php
/**
 * Panth Testimonials — Listing Template (Luma)
 * Vanilla JS, DM Sans, px units, inline CSS
 *
 * @var $block \Panth\Testimonials\Block\Testimonials
 * @var $escaper \Magento\Framework\Escaper
 */

$testimonials = $block->getTestimonials();
$categories = $block->getCategories();
$selectedCategory = $block->getSelectedCategory();
$isSubmitEnabled = $block->isSubmitEnabled();
$submitUrl = $block->getSubmitUrl();
?>

<div class="panth-testimonials-module" id="panth-testimonials-listing">
    <!-- Header -->
    <div class="testimonials-header">
        <h1 class="testimonials-title"><?= $escaper->escapeHtml(__('Customer Testimonials')) ?></h1>
        <?php if ($isSubmitEnabled): ?>
            <a href="<?= $escaper->escapeUrl($submitUrl) ?>" class="testimonials-submit-btn">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M5 12h14"/></svg>
                <?= $escaper->escapeHtml(__('Submit Testimonial')) ?>
            </a>
        <?php endif; ?>
    </div>

    <!-- Category Filter Pills -->
    <?php if ($categories->getSize() > 0): ?>
        <div class="testimonials-categories">
            <div class="panth-tt-tabs-scroll categories-scroll">
                <ul class="panth-tt-tabs">
                    <li>
                        <a href="<?= $escaper->escapeUrl($block->getUrl('testimonials')) ?>"
                           class="category-pill <?= !$selectedCategory ? 'active' : '' ?>"
                           data-category="all">
                            <?= $escaper->escapeHtml(__('All')) ?>
                        </a>
                    </li>
                    <?php foreach ($categories as $category): ?>
                        <li>
                            <a href="<?= $escaper->escapeUrl($block->getCategoryUrl($category)) ?>"
                               class="category-pill <?= $selectedCategory == $category->getId() ? 'active' : '' ?>"
                               data-category="<?= $escaper->escapeHtmlAttr($category->getId()) ?>">
                                <?= $escaper->escapeHtml($category->getName()) ?>
                            </a>
                        </li>
                    <?php endforeach; ?>
                </ul>
            </div>
        </div>
    <?php endif; ?>

    <!-- Testimonials Grid -->
    <?php if ($testimonials->getSize() > 0): ?>
        <div class="testimonials-grid">
            <?php foreach ($testimonials as $testimonial): ?>
                <a href="<?= $escaper->escapeUrl($block->getTestimonialUrl($testimonial)) ?>"
                   class="testimonial-card"
                   data-category-id="<?= $escaper->escapeHtmlAttr($testimonial->getCategoryId()) ?>">
                    <!-- Star Rating -->
                    <?php $rating = (int) $testimonial->getRating(); ?>
                    <?php if ($rating > 0): ?>
                        <div class="testimonial-rating" aria-label="<?= $escaper->escapeHtmlAttr(__('Rating: %1 out of 5', $rating)) ?>">
                            <?php for ($i = 1; $i <= 5; $i++): ?>
                                <span class="star <?= $i <= $rating ? 'filled' : '' ?>">&#9733;</span>
                            <?php endfor; ?>
                        </div>
                    <?php endif; ?>

                    <!-- Quote -->
                    <div class="testimonial-quote">
                        <span class="quote-mark">&ldquo;</span>
                        <?= $escaper->escapeHtml($testimonial->getShortContent() ?: $testimonial->getContent()) ?>
                    </div>

                    <!-- Author -->
                    <div class="testimonial-author">
                        <div class="author-avatar">
                            <?php if ($testimonial->getCustomerImage()): ?>
                                <img src="<?= $escaper->escapeUrl($testimonial->getCustomerImage()) ?>"
                                     alt="<?= $escaper->escapeHtmlAttr($testimonial->getCustomerName()) ?>"
                                     width="44" height="44" loading="lazy"/>
                            <?php else: ?>
                                <?php
                                $nameParts = explode(' ', $testimonial->getCustomerName());
                                $initials = strtoupper(substr($nameParts[0], 0, 1));
                                if (isset($nameParts[1])) {
                                    $initials .= strtoupper(substr($nameParts[1], 0, 1));
                                }
                                ?>
                                <span class="avatar-initials"><?= $escaper->escapeHtml($initials) ?></span>
                            <?php endif; ?>
                        </div>
                        <div class="author-info">
                            <span class="author-name"><?= $escaper->escapeHtml($testimonial->getCustomerName()) ?></span>
                            <?php
                            $meta = [];
                            if ($testimonial->getCustomerTitle()) {
                                $meta[] = $testimonial->getCustomerTitle();
                            }
                            if ($testimonial->getCustomerCompany()) {
                                $meta[] = $testimonial->getCustomerCompany();
                            }
                            ?>
                            <?php if (!empty($meta)): ?>
                                <span class="author-meta"><?= $escaper->escapeHtml(implode(', ', $meta)) ?></span>
                            <?php endif; ?>
                        </div>
                    </div>
                </a>
            <?php endforeach; ?>
        </div>

        <!-- Smart Pagination -->
        <?php if ($testimonials->getLastPageNumber() > 1): ?>
            <?php
            $currentPage = (int) $testimonials->getCurPage();
            $lastPage = (int) $testimonials->getLastPageNumber();
            $delta = 2;
            $pages = [1];
            $rangeStart = max(2, $currentPage - $delta);
            $rangeEnd = min($lastPage - 1, $currentPage + $delta);
            if ($rangeStart > 2) $pages[] = '...';
            for ($i = $rangeStart; $i <= $rangeEnd; $i++) $pages[] = $i;
            if ($rangeEnd < $lastPage - 1) $pages[] = '...';
            if ($lastPage > 1) $pages[] = $lastPage;
            $getPageUrl = function (int $p) use ($block): string {
                return $block->getPageUrl($p);
            };
            ?>
            <div class="testimonials-pagination">
                <?php if ($currentPage > 1): ?>
                    <a href="<?= $escaper->escapeUrl($getPageUrl($currentPage - 1)) ?>"
                       class="pagination-link prev" aria-label="<?= $escaper->escapeHtmlAttr(__('Previous')) ?>">
                        &laquo; <?= $escaper->escapeHtml(__('Prev')) ?>
                    </a>
                <?php endif; ?>

                <?php foreach ($pages as $page): ?>
                    <?php if ($page === '...'): ?>
                        <span class="pagination-dots">&hellip;</span>
                    <?php else: ?>
                        <a href="<?= $escaper->escapeUrl($getPageUrl((int) $page)) ?>"
                           class="pagination-link <?= (int) $page === $currentPage ? 'active' : '' ?>">
                            <?= (int) $page ?>
                        </a>
                    <?php endif; ?>
                <?php endforeach; ?>

                <?php if ($currentPage < $lastPage): ?>
                    <a href="<?= $escaper->escapeUrl($getPageUrl($currentPage + 1)) ?>"
                       class="pagination-link next" aria-label="<?= $escaper->escapeHtmlAttr(__('Next')) ?>">
                        <?= $escaper->escapeHtml(__('Next')) ?> &raquo;
                    </a>
                <?php endif; ?>
            </div>
        <?php endif; ?>

    <?php else: ?>
        <div class="testimonials-empty">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#A3A3A3" stroke-width="1.5"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>
            <p><?= $escaper->escapeHtml(__('No testimonials available yet.')) ?></p>
            <?php if ($isSubmitEnabled): ?>
                <a href="<?= $escaper->escapeUrl($submitUrl) ?>" class="testimonials-submit-btn">
                    <?= $escaper->escapeHtml(__('Be the first to share your experience!')) ?>
                </a>
            <?php endif; ?>
        </div>
    <?php endif; ?>

    <!-- Back to Top -->
    <?php if ($testimonials->getSize() > 6): ?>
        <div class="testimonials-back-top">
            <a href="#panth-testimonials-listing" class="back-top-link">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 15l-6-6-6 6"/></svg>
                <?= $escaper->escapeHtml(__('Back to Top')) ?>
            </a>
        </div>
    <?php endif; ?>
</div>

