        <!-- Smart Pagination -->
        <?php if ($testimonials->getLastPageNumber() > 1): ?>
            <?php
            $currentPage = (int) $testimonials->getCurPage();
            $lastPage = (int) $testimonials->getLastPageNumber();
            $delta = 2; // pages to show around current
            $pages = [];

            // Always show first page
            $pages[] = 1;

            // Range around current page
            $rangeStart = max(2, $currentPage - $delta);
            $rangeEnd = min($lastPage - 1, $currentPage + $delta);

            // Add ellipsis after first if gap
            if ($rangeStart > 2) {
                $pages[] = '...';
            }

            // Add range pages
            for ($i = $rangeStart; $i <= $rangeEnd; $i++) {
                $pages[] = $i;
            }

            // Add ellipsis before last if gap
            if ($rangeEnd < $lastPage - 1) {
                $pages[] = '...';
            }

            // Always show last page
            if ($lastPage > 1) {
                $pages[] = $lastPage;
            }

            $getPageUrl = function (int $page) use ($block): string {
                return $block->getPageUrl($page);
            };
            ?>
            <nav class="flex items-center justify-center gap-1.5 flex-wrap mt-8" aria-label="<?= $escaper->escapeHtmlAttr(__('Pagination')) ?>">
