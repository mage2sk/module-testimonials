                        <span class="px-2 py-2 text-sm text-gray-400 select-none">&hellip;</span>
                    <?php elseif ((int) $page === $currentPage): ?>
                        <span class="inline-flex items-center justify-center w-10 h-10 text-sm font-bold text-white rounded-lg"
                              style="background: var(--color-primary, #0D9488)"
                              aria-current="page"><?= (int) $page ?></span>
                    <?php else: ?>
                        <a href="<?= $escaper->escapeUrl($getPageUrl((int) $page)) ?>"
                           class="inline-flex items-center justify-center w-10 h-10 text-sm font-medium rounded-lg border border-gray-200 hover:border-gray-400 transition-colors no-underline"
                           style="color: var(--color-primary, #0D9488)">
                            <?= (int) $page ?>
                        </a>
                    <?php endif; ?>
                <?php endforeach; ?>

