<section class="pt-listing container mx-auto px-4 py-8"
         id="panth-testimonials-listing"
         x-data="{
            selectedCategory: '<?= $escaper->escapeJs($selectedCategory ?: '') ?>',
            showSubmitModal: false,
            submitForm: { name: '', email: '', title: '', company: '', rating: 5, testimonialTitle: '', content: '' },
            submitting: false,
            submitSuccess: false,
            submitError: '',
            hoverRating: 0,
            setRating(r) { this.submitForm.rating = r; },
            async submitTestimonial() {
                this.submitError = '';
                if (!this.submitForm.name || !this.submitForm.email || !this.submitForm.testimonialTitle || !this.submitForm.content) {
                    this.submitError = 'Please fill in all required fields.';
                    return;
                }
                this.submitting = true;
                try {
                    const fd = new FormData();
                    fd.append('customer_name', this.submitForm.name);
                    fd.append('customer_email', this.submitForm.email);
                    fd.append('customer_title', this.submitForm.title);
                    fd.append('customer_company', this.submitForm.company);
                    fd.append('rating', this.submitForm.rating);
                    fd.append('title', this.submitForm.testimonialTitle);
                    fd.append('content', this.submitForm.content);
                    fd.append('form_key', hyva.getFormKey());
                    const r = await fetch('<?= $escaper->escapeJs($block->getUrl('testimonials/submit/save')) ?>', { method: 'POST', body: fd });
                    if (r.ok || r.redirected) {
                        this.submitSuccess = true;
                        setTimeout(() => { this.showSubmitModal = false; this.submitSuccess = false; location.reload(); }, 2500);
                    } else { this.submitError = 'Submission failed. Please try again.'; }
                } catch(e) { this.submitError = 'An error occurred. Please try again.'; }
                finally { this.submitting = false; }
            }
         }"
         @keydown.escape.window="showSubmitModal = false">

