<?xml version="1.0"?>
<!--
/**
 * Panth Testimonials — Category View Page (Luma)
 * Reuses listing template with category filter applied by block
 */
-->
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd"
      layout="1column">
    <body>
        <referenceBlock name="page.main.title" remove="true"/>
        <referenceContainer name="content">
            <block class="Panth\Testimonials\Block\Testimonials"
                   name="testimonials.category"
                   template="Panth_Testimonials::listing.phtml"/>
        </referenceContainer>
        <referenceContainer name="before.body.end">
            <block class="Panth\Testimonials\Block\Schema"
                   name="testimonials.schema"
                   template="Panth_Testimonials::schema.phtml"/>
        </referenceContainer>
    </body>
</page>
