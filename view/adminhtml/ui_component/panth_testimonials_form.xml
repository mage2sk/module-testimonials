<?xml version="1.0"?>
<form xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd">
    <argument name="data" xsi:type="array">
        <item name="js_config" xsi:type="array">
            <item name="provider" xsi:type="string">panth_testimonials_form.panth_testimonials_form_data_source</item>
        </item>
        <item name="template" xsi:type="string">templates/form/collapsible</item>
    </argument>
    <settings>
        <buttons>
            <button name="back"><url path="*/*/"/><class>back</class><label translate="true">Back</label></button>
            <button name="delete" class="Panth\Testimonials\Block\Adminhtml\Testimonial\Edit\DeleteButton"/>
            <button name="save" class="Panth\Testimonials\Block\Adminhtml\Testimonial\Edit\SaveButton"/>
        </buttons>
        <namespace>panth_testimonials_form</namespace>
        <dataScope>data</dataScope>
        <deps><dep>panth_testimonials_form.panth_testimonials_form_data_source</dep></deps>
    </settings>
    <dataSource name="panth_testimonials_form_data_source">
        <argument name="data" xsi:type="array">
            <item name="js_config" xsi:type="array">
                <item name="component" xsi:type="string">Magento_Ui/js/form/provider</item>
            </item>
        </argument>
        <settings>
            <submitUrl path="panth_testimonials/testimonial/save"/>
        </settings>
        <dataProvider class="Panth\Testimonials\Model\Testimonial\DataProvider" name="panth_testimonials_form_data_source">
            <settings>
                <requestFieldName>id</requestFieldName>
                <primaryFieldName>testimonial_id</primaryFieldName>
            </settings>
        </dataProvider>
    </dataSource>
    <fieldset name="general" sortOrder="10">
        <settings><label translate="true">Testimonial Details</label></settings>
        <field name="testimonial_id" formElement="input"><settings><visible>false</visible><dataType>text</dataType></settings></field>
        <field name="customer_name" formElement="input" sortOrder="10"><settings><validation><rule name="required-entry" xsi:type="boolean">true</rule></validation><dataType>text</dataType><label translate="true">Customer Name</label></settings></field>
        <field name="customer_email" formElement="input" sortOrder="20"><settings><dataType>text</dataType><label translate="true">Email</label></settings></field>
        <field name="customer_title" formElement="input" sortOrder="30"><settings><dataType>text</dataType><label translate="true">Job Title</label></settings></field>
        <field name="customer_company" formElement="input" sortOrder="40"><settings><dataType>text</dataType><label translate="true">Company</label></settings></field>
        <field name="rating" formElement="input" sortOrder="50"><settings><validation><rule name="required-entry" xsi:type="boolean">true</rule></validation><dataType>text</dataType><label translate="true">Rating (1-5)</label></settings></field>
        <field name="title" formElement="input" sortOrder="60"><settings><validation><rule name="required-entry" xsi:type="boolean">true</rule></validation><dataType>text</dataType><label translate="true">Testimonial Title</label></settings></field>
        <field name="content" formElement="textarea" sortOrder="70"><settings><validation><rule name="required-entry" xsi:type="boolean">true</rule></validation><dataType>text</dataType><label translate="true">Full Content</label></settings></field>
        <field name="short_content" formElement="textarea" sortOrder="75"><settings><dataType>text</dataType><label translate="true">Short Excerpt (for cards)</label></settings></field>
        <field name="url_key" formElement="input" sortOrder="80"><settings><dataType>text</dataType><label translate="true">URL Key</label><notice translate="true">Leave empty to auto-generate</notice></settings></field>
        <field name="status" formElement="select" sortOrder="90">
            <settings><dataType>text</dataType><label translate="true">Status</label></settings>
            <formElements><select><settings><options class="Panth\Testimonials\Model\Config\Source\Status"/></settings></select></formElements>
        </field>
        <field name="is_featured" formElement="checkbox" sortOrder="95">
            <argument name="data" xsi:type="array"><item name="config" xsi:type="array"><item name="default" xsi:type="number">0</item></item></argument>
            <settings><dataType>boolean</dataType><label translate="true">Featured</label></settings>
            <formElements><checkbox><settings><valueMap><map name="false" xsi:type="number">0</map><map name="true" xsi:type="number">1</map></valueMap><prefer>toggle</prefer></settings></checkbox></formElements>
        </field>
        <field name="category_id" formElement="select" sortOrder="100">
            <settings><dataType>text</dataType><label translate="true">Category</label></settings>
            <formElements><select><settings><options class="Panth\Testimonials\Model\Config\Source\CategoryList"/></settings></select></formElements>
        </field>
        <field name="sort_order" formElement="input" sortOrder="110"><settings><dataType>text</dataType><label translate="true">Sort Order</label></settings></field>
    </fieldset>
</form>
