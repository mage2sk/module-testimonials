<?xml version="1.0"?>
<listing xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd">
    <argument name="data" xsi:type="array">
        <item name="js_config" xsi:type="array">
            <item name="provider" xsi:type="string">panth_testimonials_listing.panth_testimonials_listing_data_source</item>
        </item>
    </argument>
    <settings>
        <spinner>panth_testimonials_columns</spinner>
        <deps><dep>panth_testimonials_listing.panth_testimonials_listing_data_source</dep></deps>
        <buttons>
            <button name="add"><url path="*/*/new"/><class>primary</class><label translate="true">Add New Testimonial</label></button>
        </buttons>
    </settings>
    <dataSource name="panth_testimonials_listing_data_source" component="Magento_Ui/js/grid/provider">
        <settings>
            <storageConfig>
                <param name="indexField" xsi:type="string">testimonial_id</param>
            </storageConfig>
            <updateUrl path="mui/index/render"/>
        </settings>
        <dataProvider class="Magento\Framework\View\Element\UiComponent\DataProvider\DataProvider" name="panth_testimonials_listing_data_source">
            <settings>
                <requestFieldName>id</requestFieldName>
                <primaryFieldName>testimonial_id</primaryFieldName>
            </settings>
        </dataProvider>
    </dataSource>
    <listingToolbar name="listing_top">
        <bookmark name="bookmarks"/>
        <columnsControls name="columns_controls"/>
        <filters name="listing_filters"/>
        <massaction name="listing_massaction"><action name="delete"><settings><confirm><message translate="true">Delete selected?</message><title translate="true">Delete</title></confirm><url path="panth_testimonials/testimonial/massDelete"/><type>delete</type><label translate="true">Delete</label></settings></action></massaction>
        <paging name="listing_paging"/>
    </listingToolbar>
    <columns name="panth_testimonials_columns">
        <selectionsColumn name="ids" sortOrder="0">
            <settings><indexField>testimonial_id</indexField></settings>
        </selectionsColumn>
        <column name="testimonial_id" sortOrder="10">
            <settings><filter>textRange</filter><label translate="true">ID</label><sorting>desc</sorting></settings>
        </column>
        <column name="customer_name" sortOrder="20">
            <settings><filter>text</filter><label translate="true">Customer Name</label></settings>
        </column>
        <column name="title" sortOrder="30">
            <settings><filter>text</filter><label translate="true">Title</label></settings>
        </column>
        <column name="rating" sortOrder="40">
            <settings><filter>textRange</filter><label translate="true">Rating</label></settings>
        </column>
        <column name="status" component="Magento_Ui/js/grid/columns/select" sortOrder="50">
            <settings>
                <filter>select</filter>
                <label translate="true">Status</label>
                <dataType>select</dataType>
                <options class="Panth\Testimonials\Model\Config\Source\Status"/>
            </settings>
        </column>
        <column name="is_featured" component="Magento_Ui/js/grid/columns/select" sortOrder="55">
            <settings><filter>select</filter><label translate="true">Featured</label><dataType>select</dataType>
                <options class="Magento\Config\Model\Config\Source\Yesno"/>
            </settings>
        </column>
        <column name="created_at" class="Magento\Ui\Component\Listing\Columns\Date" component="Magento_Ui/js/grid/columns/date" sortOrder="60">
            <settings><filter>dateRange</filter><label translate="true">Created</label><dataType>date</dataType></settings>
        </column>
        <actionsColumn name="actions" class="Panth\Testimonials\Ui\Component\Listing\Column\Actions" sortOrder="100">
            <settings><indexField>testimonial_id</indexField></settings>
        </actionsColumn>
    </columns>
</listing>
